{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gss.dev/schemas/registry/registration-request.schema.json",
  "title": "GSS Registry Registration Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["shop_domain", "endpoint", "gss_version", "contact_email"],
  "properties": {
    "shop_domain": {
      "type": "string",
      "minLength": 3,
      "maxLength": 253,
      "pattern": "^[a-z0-9.-]+$"
    },
    "endpoint": {
      "type": "string",
      "format": "uri"
    },
    "gss_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "contact_email": {
      "type": "string",
      "format": "email"
    }
  }
}
